# OpenRouter API Key (for LLM summarization)
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Pinecone API Key (for vector storage)
# Get your key at https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone Environment (default: us-east-1)
PINECONE_ENV=us-east-1

# Pinecone Index Name (default: arxiv-pulse)
PINECONE_INDEX=arxiv-pulse

# Ollama Local (fallback LLM)
# Run: ollama serve
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Telegram Bot (for alerts)
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
